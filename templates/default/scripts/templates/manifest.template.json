{
	"manifest_version": 3,
	"name": "__EXT_NAME__",
	"version": "__VERSION__",
	"description": "__DESCRIPTION__",
	"permissions": [
		"scripting",
		"activeTab",
		"tabs",
		"storage"
	],
	"host_permissions": [
		"https://dev.azure.com/*"
	],
	"content_scripts": [
		{
			"matches": [
				"https://dev.azure.com/*"
			],
			"js": [
				"content.js"
			],
			"run_at": "document_idle"
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"app.js",
				"overlay.html",
				"tailwind.css"
			],
			"matches": [
				"https://dev.azure.com/*"
			]
		}
	]
}
